{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noEmit": true,
    "types": ["node", "vitest/globals", "playwright"]
  },
  "include": ["test/**/*.ts", "e2e/**/*.ts", "playwright.config.ts"]
}
